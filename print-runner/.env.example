# Which branch's print channel to subscribe to.
BRANCH_ID=1

# WiFi thermal printer (Zywell ZY905-K4-W and any standard ESC/POS).
PRINTER_HOST=192.168.1.50
PRINTER_PORT=9100
# Receipt paper width in characters (32 for 58mm, 48 for 80mm).
PRINTER_WIDTH=48

# Reverb / Pusher connection.
REVERB_HOST=starcoffee.my
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_APP_KEY=replace-with-REVERB_APP_KEY-from-server
