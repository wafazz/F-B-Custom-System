		-
			message: '#^Anonymous function should return array\{name\: string, quantity\: int\<0, max\>, unit_price\: float, line_total\: float, modifiers\: Illuminate\\Support\\Collection\<int, array\{option_name\: mixed\}\>\} but returns array\{name\: string, quantity\: int\<0, max\>, unit_price\: float, line_total\: float, modifiers\: Illuminate\\Support\\Collection\<int, array\{option_name\: mixed\}\>\}\.$#'
			identifier: return.type
			count: 1
			path: app/Http/Controllers/Pos/WalkInController.php

		-
			message: '#^Using nullsafe property access "\?\-\>label_size" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: app/Http/Controllers/Pos/WalkInController.php

		-
			message: '#^Using nullsafe property access "\?\-\>service_charge_rate" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: app/Http/Controllers/Pos/WalkInController.php

		-
