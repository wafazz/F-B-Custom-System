parameters:
	ignoreErrors:
		-
			message: '#^Anonymous function should return array\{number\: string, status\: ''cancelled''\|''completed''\|''pending''\|''preparing''\|''ready''\|''refunded'', total\: float, created_at\: string\|null, branch\: string\|null, items\: Illuminate\\Support\\Collection\<int, array\{product\: mixed, quantity\: mixed, unit_price\: float, modifiers\: mixed\}\>\} but returns array\{number\: string, status\: ''cancelled''\|''completed''\|''pending''\|''preparing''\|''ready''\|''refunded'', total\: float, created_at\: string\|null, branch\: string\|null, items\: Illuminate\\Support\\Collection\<int, array\{product\: mixed, quantity\: mixed, unit_price\: float, modifiers\: mixed\}\>\}\.$#'
			identifier: return.type
			count: 1
			path: app/Http/Controllers/Api/ProfileController.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$code\.$#'
